@Test
void addComment_hitsEndpoint() throws Exception {
    service.addRequest(new ServiceRequest("10", "u1", "title", "desc", "LOW"));

    Comment comment = new Comment("C1", "alice", "test comment");

    mockMvc.perform(post("/api/messages/10/comments")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(mapper.writeValueAsString(comment)))
            .andExpect(status().isOk());
}

@Test
void addComment_responseContainsComment() throws Exception {
    service.addRequest(new ServiceRequest("11", "u1", "title", "desc", "LOW"));

    Comment comment = new Comment("C1", "alice", "check response");

    mockMvc.perform(post("/api/messages/11/comments")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(mapper.writeValueAsString(comment)))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$.comments[0].body").value("check response"))
            .andExpect(jsonPath("$.comments[0].authorId").value("alice"));
}

@Test
void getComments_hitsEndpoint() throws Exception {
    service.addRequest(new ServiceRequest("12", "u1", "title", "desc", "LOW"));
    service.addComment("12", new Comment("C1", "bob", "a note"));

    mockMvc.perform(get("/api/messages/12/comments"))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$[0].body").value("a note"));
}

@Test
void addComment_blankBody_returnsBadRequest() throws Exception {
    service.addRequest(new ServiceRequest("13", "u1", "title", "desc", "LOW"));

    Comment bad = new Comment("C1", "alice", "   ");

    mockMvc.perform(post("/api/messages/13/comments")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(mapper.writeValueAsString(bad)))
            .andExpect(status().is5xxServerError());
}

