@Test
void getHistory_hitsEndpoint() throws Exception {
    service.addRequest(new ServiceRequest("20", "u1", "title", "desc", "LOW"));

    mockMvc.perform(get("/api/messages/20/history"))
            .andExpect(status().isOk());
