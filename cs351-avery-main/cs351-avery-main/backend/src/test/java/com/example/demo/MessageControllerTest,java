@Test
void getHistory_afterCreate_containsCreatedEntry() throws Exception {
    service.addRequest(new ServiceRequest("21", "u1", "title", "desc", "LOW"));

    mockMvc.perform(get("/api/messages/21/history"))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$[0].action").value("CREATED"));
}

@Test
void getHistory_afterStatusChange_containsStatusChangedEntry() throws Exception {
    service.addRequest(new ServiceRequest("22", "u1", "title", "desc", "LOW"));

    ServiceRequest updated = new ServiceRequest("22", "u1", "title", "desc", "LOW");
    updated.setStatus("Closed");

    mockMvc.perform(put("/api/messages/22")
                    .contentType(MediaType.APPLICATION_JSON)
                    .content(mapper.writeValueAsString(updated)))
            .andExpect(status().isOk());

    mockMvc.perform(get("/api/messages/22/history"))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$[?(@.action == 'STATUS_CHANGED')]").exists());
}

@Test
void getHistory_afterComment_containsCommentAddedEntry() throws Exception {
    service.addRequest(new ServiceRequest("23", "u1", "title", "desc", "LOW"));
    service.addComment("23", new Comment("C1", "alice", "note"));

    mockMvc.perform(get("/api/messages/23/history"))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$[?(@.action == 'COMMENT_ADDED')]").exists());
}

@Test
void getHistory_unknownId_returnsEmptyArray() throws Exception {
    mockMvc.perform(get("/api/messages/nonexistent/history"))
            .andExpect(status().isOk())
            .andExpect(jsonPath("$").isArray())
            .andExpect(jsonPath("$").isEmpty());
}